# ── LLM ──────────────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=./data
MAX_CSV_FILE_SIZE_MB=100

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for local / staging environments
CORS_ORIGINS=http://localhost:3000

# Optional regex for dynamic origins (e.g. Firebase Hosting previews).
# Leave empty if not needed.
# Example: https://your-project\.(web\.app|firebaseapp\.com)$
CORS_ORIGIN_REGEX=

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200   # 30 days

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use default SQLite at DATA_DIR/pulsebridge.db
# For PostgreSQL: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=
