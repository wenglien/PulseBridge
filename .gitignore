# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Secrets (NEVER commit these) ─────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Backend ───────────────────────────────────────────────────────────────────
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/venv/
backend/.venv/
backend/data/          # session files, uploaded XMLs
backend/*.egg-info/
backend/.pytest_cache/
backend/.mypy_cache/

# ── Frontend ──────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/          # static export build output
frontend/.vercel/
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# ── Firebase ──────────────────────────────────────────────────────────────────
.firebase/
.firebaserc.local

# ── IDE / tooling ─────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.swp
*.swo
